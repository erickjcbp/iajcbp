{
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "coroinhas.jcbplimeira.com" }], "destination": "/projetos/acolitos/login.html", "permanent": false },
    { "source": "/",          "destination": "/projetos/central/login.html",     "permanent": false },
    { "source": "/central",   "destination": "/projetos/central/central.html",   "permanent": false },
    { "source": "/pastorais", "destination": "/projetos/central/pastorais.html", "permanent": false },
    { "source": "/acolitos",  "destination": "/projetos/acolitos/index.html",     "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
